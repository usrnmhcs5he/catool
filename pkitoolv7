set -euo pipefail

# Script version
SCRIPT_VERSION="7"

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------
CA_DIR="CA"
CA_KEY="$CA_DIR/ca.key"
CA_CRT="$CA_DIR/ca.crt"
INDEX="$CA_DIR/index.txt"
INDEX_ATTR="$CA_DIR/index.txt.attr"
SERIAL="$CA_DIR/serial"
CRL_NUMBER="$CA_DIR/crlnumber"

# YubiKey Configuration
YUBIKEY_MODE_FILE="$CA_DIR/.yubikey_mode"
YUBIKEY_SLOT="9c"  # Digital Signature slot - best for CA signing
YUBIKEY_SLOT_HEX="02"  # Slot 9c = id 02 in PKCS#11

# PKCS#11 library paths (will be auto-detected)
YKCS11_LIB=""
PKCS11_ENGINE=""
CRL_FILE="$CA_DIR/ca.crl"
CA_CONFIG="$CA_DIR/ca.cnf"

# Default values
DEFAULT_CA_DAYS=3650
DEFAULT_CERT_DAYS=365
DEFAULT_RSA_SIZE=4096
DEFAULT_EC_CURVE="prime256v1"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# -----------------------------------------------------------------------------
# Helper Functions
# -----------------------------------------------------------------------------
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

die() {
    log_error "$1"
    exit 1
}

# Convert string to uppercase (Bash 3.x compatible)
to_uppercase() {
    echo "$1" | tr '[:lower:]' '[:upper:]'
}

# Convert string to lowercase (Bash 3.x compatible)
to_lowercase() {
    echo "$1" | tr '[:upper:]' '[:lower:]'
}

# Check if required tools are available
check_dependencies() {
    local deps=("openssl" "mkdir" "cat" "rm" "cp" "tr")
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            die "Required command '$dep' not found. Please install it."
        fi
    done
    
    # Check OpenSSL version (need 1.1.1+ for some features)
    local openssl_version
    openssl_version=$(openssl version | awk '{print $2}')
    log_info "OpenSSL version: $openssl_version"
}

# Validate Common Name (no dangerous characters)
validate_cn() {
    local cn="$1"
    if [[ -z "$cn" ]]; then
        die "Common Name cannot be empty"
    fi
    if [[ ${#cn} -gt 64 ]]; then
        die "Common Name too long (max 64 characters)"
    fi
    if [[ "$cn" =~ [/\\:\*\?\"\<\>\|] ]]; then
        die "Common Name contains invalid characters"
    fi
    # Check for directory traversal
    if [[ "$cn" == *".."* ]]; then
        die "Common Name cannot contain '..'"
    fi
}

# Validate IP address (IPv4 or IPv6)
is_valid_ipv4() {
    local ip="$1"
    local IFS='.'
    read -ra octets <<< "$ip"
    [[ ${#octets[@]} -eq 4 ]] || return 1
    for octet in "${octets[@]}"; do
        [[ "$octet" =~ ^[0-9]+$ ]] || return 1
        ((octet >= 0 && octet <= 255)) || return 1
    done
    return 0
}

is_valid_ipv6() {
    local ip="$1"
    # Basic IPv6 validation - must contain at least one colon and valid hex chars
    if [[ ! "$ip" =~ : ]]; then
        return 1
    fi
    # Check for valid characters only
    if [[ ! "$ip" =~ ^[0-9a-fA-F:]+$ ]]; then
        return 1
    fi
    # Check for valid structure (not more than 8 groups, :: only once)
    local double_colon_count
    double_colon_count=$(grep -o '::' <<< "$ip" | wc -l)
    if ((double_colon_count > 1)); then
        return 1
    fi
    return 0
}

is_ip_address() {
    local addr="$1"
    is_valid_ipv4 "$addr" || is_valid_ipv6 "$addr"
}

# Validate numeric input
validate_number() {
    local num="$1"
    local min="$2"
    local max="$3"
    local name="$4"
    
    if [[ ! "$num" =~ ^[0-9]+$ ]]; then
        die "$name must be a number"
    fi
    if ((num < min || num > max)); then
        die "$name must be between $min and $max"
    fi
}

# Secure passphrase reading
read_passphrase() {
    local prompt="$1"
    local var_name="$2"
    local confirm="${3:-false}"
    
    local pass1 pass2
    
    read -rs -p "$prompt" pass1
    echo ""
    
    if [[ "$confirm" == "true" && -n "$pass1" ]]; then
        read -rs -p "Confirm passphrase: " pass2
        echo ""
        if [[ "$pass1" != "$pass2" ]]; then
            die "Passphrases do not match"
        fi
    fi
    
    eval "$var_name=\"\$pass1\""
}

# Generate random serial if needed
generate_serial() {
    openssl rand -hex 8 | tr '[:lower:]' '[:upper:]'
}

# -----------------------------------------------------------------------------
# YubiKey Functions
# -----------------------------------------------------------------------------

# Detect PKCS#11 library paths
detect_pkcs11_paths() {
    # Detect ykcs11 library
    local ykcs11_paths=(
        "/usr/local/lib/libykcs11.dylib"           # macOS Homebrew
        "/usr/local/lib/libykcs11.so"              # Linux local
        "/usr/lib/x86_64-linux-gnu/libykcs11.so"   # Debian/Ubuntu x64
        "/usr/lib/libykcs11.so"                    # Generic Linux
        "/opt/homebrew/lib/libykcs11.dylib"        # macOS ARM Homebrew
    )
    
    for path in "${ykcs11_paths[@]}"; do
        if [[ -f "$path" ]]; then
            YKCS11_LIB="$path"
            break
        fi
    done
    
    # Detect OpenSSL PKCS#11 engine
    local engine_paths=(
        "/usr/local/lib/engines-3/pkcs11.dylib"    # macOS OpenSSL 3
        "/usr/local/lib/engines-1.1/pkcs11.dylib"  # macOS OpenSSL 1.1
        "/usr/lib/x86_64-linux-gnu/engines-3/pkcs11.so"  # Linux OpenSSL 3
        "/usr/lib/x86_64-linux-gnu/engines-1.1/pkcs11.so" # Linux OpenSSL 1.1
        "/usr/lib/engines-3/pkcs11.so"             # Generic Linux
        "/opt/homebrew/lib/engines-3/pkcs11.dylib" # macOS ARM
    )
    
    for path in "${engine_paths[@]}"; do
        if [[ -f "$path" ]]; then
            PKCS11_ENGINE="$path"
            break
        fi
    done
}

# Check if YubiKey tools are available
check_yubikey_tools() {
    local missing_tools=()
    
    if ! command -v yubico-piv-tool &> /dev/null; then
        missing_tools+=("yubico-piv-tool")
    fi
    
    if ! command -v ykman &> /dev/null; then
        missing_tools+=("ykman (yubikey-manager)")
    fi
    
    detect_pkcs11_paths
    
    if [[ -z "$YKCS11_LIB" ]]; then
        missing_tools+=("libykcs11 (PKCS#11 library)")
    fi
    
    if [[ ${#missing_tools[@]} -gt 0 ]]; then
        log_error "Missing YubiKey tools: ${missing_tools[*]}"
        echo ""
        echo "Please install the required tools. See REQUIREMENTS.md for instructions."
        echo ""
        return 1
    fi
    
    return 0
}

# Check if YubiKey is connected
check_yubikey_connected() {
    if ! ykman list 2>/dev/null | grep -q "YubiKey"; then
        log_error "No YubiKey detected. Please insert your YubiKey."
        return 1
    fi
    return 0
}

# Show YubiKey status
show_yubikey_status() {
    log_info "=== YubiKey Status ==="
    echo ""
    
    if ! check_yubikey_tools; then
        return 1
    fi
    
    if ! check_yubikey_connected; then
        return 1
    fi
    
    echo "Device Information:"
    ykman info
    echo ""
    
    echo "PIV Slot Status:"
    yubico-piv-tool -a status
    echo ""
    
    # Check if slot 9c has a key
    if yubico-piv-tool -a status 2>/dev/null | grep -q "Slot 9c"; then
        log_info "Slot 9c (Digital Signature) contains a key/certificate"
    else
        log_info "Slot 9c (Digital Signature) is empty"
    fi
}

# Check if CA is using YubiKey mode
is_yubikey_ca() {
    [[ -f "$YUBIKEY_MODE_FILE" ]]
}

# Generate CA key on YubiKey
generate_ca_key_on_yubikey() {
    local algorithm="$1"
    local pin_policy="$2"
    local touch_policy="$3"
    local management_key="$4"
    
    log_info "Generating CA private key on YubiKey slot $YUBIKEY_SLOT..."
    log_warn "This key will be NON-EXPORTABLE for maximum security."
    echo ""
    
    local algo_flag
    case "$algorithm" in
        "RSA2048") algo_flag="RSA2048" ;;
        "ECCP256") algo_flag="ECCP256" ;;
        "ECCP384") algo_flag="ECCP384" ;;
        *) die "Unsupported algorithm: $algorithm" ;;
    esac
    
    # Generate key on YubiKey
    local pubkey_file="$CA_DIR/ca_pubkey.pem"
    
    if [[ "$management_key" == "default" ]]; then
        yubico-piv-tool -s "$YUBIKEY_SLOT" -a generate \
            -A "$algo_flag" \
            --pin-policy="$pin_policy" \
            --touch-policy="$touch_policy" \
            -o "$pubkey_file" || die "Failed to generate key on YubiKey"
    else
        yubico-piv-tool -s "$YUBIKEY_SLOT" -a generate \
            -A "$algo_flag" \
            --pin-policy="$pin_policy" \
            --touch-policy="$touch_policy" \
            -k "$management_key" \
            -o "$pubkey_file" || die "Failed to generate key on YubiKey"
    fi
    
    log_success "Key generated on YubiKey"
    echo "$pubkey_file"
}

# Import existing CA key to YubiKey
import_ca_key_to_yubikey() {
    local key_file="$1"
    local management_key="$2"
    local pin_policy="$3"
    local touch_policy="$4"
    
    log_info "Importing CA private key to YubiKey slot $YUBIKEY_SLOT..."
    log_warn "After import, consider securely deleting the original key file."
    echo ""
    
    if [[ "$management_key" == "default" ]]; then
        yubico-piv-tool -s "$YUBIKEY_SLOT" -a import-key \
            --pin-policy="$pin_policy" \
            --touch-policy="$touch_policy" \
            -i "$key_file" || die "Failed to import key to YubiKey"
    else
        yubico-piv-tool -s "$YUBIKEY_SLOT" -a import-key \
            --pin-policy="$pin_policy" \
            --touch-policy="$touch_policy" \
            -k "$management_key" \
            -i "$key_file" || die "Failed to import key to YubiKey"
    fi
    
    log_success "Key imported to YubiKey"
}

# Import CA certificate to YubiKey
import_ca_cert_to_yubikey() {
    local cert_file="$1"
    local management_key="$2"
    
    log_info "Importing CA certificate to YubiKey slot $YUBIKEY_SLOT..."
    
    if [[ "$management_key" == "default" ]]; then
        yubico-piv-tool -s "$YUBIKEY_SLOT" -a import-certificate \
            -i "$cert_file" || die "Failed to import certificate to YubiKey"
    else
        yubico-piv-tool -s "$YUBIKEY_SLOT" -a import-certificate \
            -k "$management_key" \
            -i "$cert_file" || die "Failed to import certificate to YubiKey"
    fi
    
    log_success "Certificate imported to YubiKey"
}

# Create self-signed CA certificate using YubiKey
create_ca_cert_with_yubikey() {
    local pubkey_file="$1"
    local ca_cn="$2"
    local ca_days="$3"
    local pin="$4"
    
    log_info "Creating self-signed CA certificate using YubiKey..."
    
    # Create certificate using yubico-piv-tool
    yubico-piv-tool -a verify-pin -P "$pin" \
        -a selfsign-certificate \
        -s "$YUBIKEY_SLOT" \
        -S "/CN=$ca_cn/" \
        --valid-days="$ca_days" \
        -i "$pubkey_file" \
        -o "$CA_CRT" || die "Failed to create CA certificate"
    
    log_success "CA certificate created"
}

# Sign certificate using YubiKey (via PKCS#11)
sign_with_yubikey() {
    local csr_file="$1"
    local crt_file="$2"
    local extensions="$3"
    local days="$4"
    
    if [[ -z "$YKCS11_LIB" ]]; then
        detect_pkcs11_paths
    fi
    
    if [[ -z "$YKCS11_LIB" ]]; then
        die "PKCS#11 library not found. Please install libykcs11."
    fi
    
    # Create temporary config with PKCS#11 engine
    local temp_config
    temp_config=$(mktemp)
    
    cat > "$temp_config" <<-EOFENGINE
openssl_conf = openssl_init

[openssl_init]
engines = engine_section

[engine_section]
pkcs11 = pkcs11_section

[pkcs11_section]
engine_id = pkcs11
MODULE_PATH = $YKCS11_LIB
init = 0

EOFENGINE
    
    # Append the CA config
    cat "$CA_CONFIG" >> "$temp_config"
    
    # Update config to use PKCS#11 key
    sed -i.bak "s|private_key       = .*|private_key       = pkcs11:object=Private key for Digital Signature;type=private|g" "$temp_config"
    sed -i.bak "s|default_days      = 365|default_days      = $days|g" "$temp_config"
    rm -f "$temp_config.bak" 2>/dev/null || true
    
    log_info "Signing certificate with YubiKey..."
    log_warn "You may need to enter your PIN and/or touch the YubiKey."
    echo ""
    
    # Ensure newcerts directory exists
    mkdir -p "$CA_DIR/newcerts"
    
    OPENSSL_CONF="$temp_config" PKCS11_MODULE_PATH="$YKCS11_LIB" \
    openssl ca -batch \
        -engine pkcs11 \
        -keyform engine \
        -config "$temp_config" \
        -cert "$CA_CRT" \
        -in "$csr_file" \
        -out "$crt_file" \
        -extensions "$extensions" \
        -notext || {
            rm -f "$temp_config"
            die "Failed to sign certificate with YubiKey"
        }
    
    rm -f "$temp_config"
    log_success "Certificate signed with YubiKey"
}

# Get YubiKey PIN from user
get_yubikey_pin() {
    local var_name="$1"
    read_passphrase "Enter YubiKey PIN: " "$var_name" false
}

# Get YubiKey management key
get_management_key() {
