select_cert_type() {
    echo ""
    echo "Select certificate type:"
    echo ""
    echo "  Server Certificates:"
    echo "    1) web-server     - HTTPS/TLS web server"
    echo "    2) radius-server  - RADIUS/EAP-TLS server (FreeRADIUS, NPS)"
    echo "    3) vpn-server     - VPN server (OpenVPN, IKEv2/IPsec)"
    echo ""
    echo "  Client Certificates:"
    echo "    4) tls-client     - Generic TLS client authentication"
    echo "    5) wifi-client    - WiFi EAP-TLS / WPA Enterprise client"
    echo "    6) vpn-client     - VPN client certificate"
    echo ""
    echo "  Other:"
    echo "    7) code-signing   - Code/software signing"
    echo "    8) email          - S/MIME email encryption/signing"
    echo ""
    read -rp "Choice [1]: " choice
    choice="${choice:-1}"
    
    case "$choice" in
        1) CERT_TYPE="web-server"; EXT_SECTION="web_server" ;;
        2) CERT_TYPE="radius-server"; EXT_SECTION="radius_server" ;;
        3) CERT_TYPE="vpn-server"; EXT_SECTION="vpn_server" ;;
        4) CERT_TYPE="tls-client"; EXT_SECTION="tls_client" ;;
        5) CERT_TYPE="wifi-client"; EXT_SECTION="wifi_client" ;;
        6) CERT_TYPE="vpn-client"; EXT_SECTION="vpn_client" ;;
        7) CERT_TYPE="code-signing"; EXT_SECTION="code_signing" ;;
        8) CERT_TYPE="email"; EXT_SECTION="email_cert" ;;
        *) die "Invalid certificate type selection" ;;
    esac
    
    log_info "Selected: $CERT_TYPE"
}

select_key_options() {
    echo ""
    echo "Select key type(s) to generate:"
    echo "  1) RSA only"
    echo "  2) ECDSA only"
    echo "  3) Both RSA and ECDSA"
    read -rp "Choice [3]: " key_choice
    key_choice="${key_choice:-3}"
    
    GENERATE_RSA=false
    GENERATE_EC=false
    
    case "$key_choice" in
        1) GENERATE_RSA=true ;;
        2) GENERATE_EC=true ;;
        3) GENERATE_RSA=true; GENERATE_EC=true ;;
        *) die "Invalid key type selection" ;;
    esac
    
    if [[ "$GENERATE_RSA" == "true" ]]; then
        echo ""
        echo "Select RSA key size:"
        echo "  1) 2048 bits"
        echo "  2) 3072 bits"
        echo "  3) 4096 bits"
        read -rp "Choice [2]: " rsa_choice
        rsa_choice="${rsa_choice:-2}"
        case "$rsa_choice" in
            1) RSA_SIZE=2048 ;;
            2) RSA_SIZE=3072 ;;
            3) RSA_SIZE=4096 ;;
            *) die "Invalid RSA size selection" ;;
        esac
    fi
    
    if [[ "$GENERATE_EC" == "true" ]]; then
        echo ""
        echo "Select EC curve:"
        echo "  1) prime256v1 / P-256 (most compatible)"
        echo "  2) secp384r1 / P-384"
        echo "  3) secp521r1 / P-521"
        read -rp "Choice [1]: " ec_choice
        ec_choice="${ec_choice:-1}"
        case "$ec_choice" in
            1) EC_CURVE="prime256v1" ;;
            2) EC_CURVE="secp384r1" ;;
            3) EC_CURVE="secp521r1" ;;
            *) die "Invalid EC curve selection" ;;
        esac
    fi
}

get_cert_details() {
    echo ""
    read -rp "Enter Common Name (e.g., server.example.com or user@example.com): " CN
    validate_cn "$CN"
    
    # Optional: Organization details
    read -rp "Enter Organization (optional, press Enter to skip): " ORG
    read -rp "Enter Organizational Unit (optional, press Enter to skip): " OU
    read -rp "Enter Country Code (2 letters, optional): " COUNTRY
    if [[ -n "$COUNTRY" ]] && [[ ! "$COUNTRY" =~ ^[A-Za-z]{2}$ ]]; then
        log_warn "Invalid country code, ignoring"
        COUNTRY=""
    fi
    # Convert to uppercase (Bash 3.x compatible)
    COUNTRY=$(to_uppercase "$COUNTRY")
    
    # Build subject string
    SUBJECT=""
    [[ -n "$COUNTRY" ]] && SUBJECT+="/C=$COUNTRY"
    [[ -n "$ORG" ]] && SUBJECT+="/O=$ORG"
    [[ -n "$OU" ]] && SUBJECT+="/OU=$OU"
    SUBJECT+="/CN=$CN"
    
    # Certificate validity
    read -rp "Enter certificate validity in days [$DEFAULT_CERT_DAYS]: " CERT_DAYS
    CERT_DAYS="${CERT_DAYS:-$DEFAULT_CERT_DAYS}"
    validate_number "$CERT_DAYS" 1 3650 "Certificate validity"
}

get_san_entries() {
    echo ""
    log_info "Subject Alternative Names (SANs)"
    log_info "The Common Name ($CN) will be automatically added as the first SAN."
    echo ""
    read -rp "Enter additional SANs (comma-separated DNS names or IPs, or press Enter for none): " SAN_INPUT
    
    # Build SAN array, starting with CN
    SAN_ARRAY=()
    
    # Determine if CN is IP or DNS
    if is_ip_address "$CN"; then
        SAN_ARRAY+=("IP:$CN")
    else
        SAN_ARRAY+=("DNS:$CN")
    fi
    
    # Process additional SANs
    if [[ -n "$SAN_INPUT" ]]; then
        IFS=',' read -ra EXTRA_SANS <<< "$SAN_INPUT"
        for san in "${EXTRA_SANS[@]}"; do
            san="${san#"${san%%[![:space:]]*}"}" # Trim leading whitespace
            san="${san%"${san##*[![:space:]]}"}" # Trim trailing whitespace
            
            if [[ -z "$san" ]]; then
                continue
            fi
            
            if is_ip_address "$san"; then
                SAN_ARRAY+=("IP:$san")
            else
                SAN_ARRAY+=("DNS:$san")
            fi
        done
    fi
    
    # For email certs, add email SAN if CN looks like an email
    if [[ "$CERT_TYPE" == "email" ]] && [[ "$CN" =~ @ ]]; then
        SAN_ARRAY+=("email:$CN")
    fi
    
    # Build SAN extension string
    SAN_EXT=$(IFS=,; echo "${SAN_ARRAY[*]}")
    
    log_info "SANs to be included: $SAN_EXT"
}

generate_certificate() {
    local key_type="$1"  # rsa or ec
    local key_param="$2" # size for RSA, curve for EC
    
    # Create output directory
    local safe_cn="${CN//[^a-zA-Z0-9._-]/_}"
    local output_dir="$safe_cn"
    mkdir -p "$output_dir"
    
    local base_name="$safe_cn-$key_type-$CERT_TYPE"
    local key_file="$output_dir/$base_name.key"
    local csr_file="$output_dir/$base_name.csr"
    local crt_file="$output_dir/$base_name.crt"
    local pfx_file="$output_dir/$base_name.pfx"
    local pem_file="$output_dir/$base_name-fullchain.pem"
    local cert_pem_file="$output_dir/$base_name.pem"
    local chain_pem_file="$output_dir/$base_name-chain.pem"
    local bundle_pem_file="$output_dir/$base_name-bundle.pem"
    local cert_der_file="$output_dir/$base_name-cert.der"
    local key_der_file="$output_dir/$base_name-key.der"
    
    log_info "Generating $key_type certificate..."
    
    # Generate private key
    if [[ "$key_type" == "rsa" ]]; then
        openssl genrsa -out "$key_file" "$key_param" 2>/dev/null
    else
        openssl ecparam -name "$key_param" -genkey -noout -out "$key_file" 2>/dev/null
    fi
    chmod 600 "$key_file"
    
    # Generate CSR with SANs
    openssl req -new -key "$key_file" -out "$csr_file" \
        -subj "$SUBJECT" \
        -addext "subjectAltName = $SAN_EXT"
    
    # Ensure newcerts directory exists
    mkdir -p "$CA_DIR/newcerts"
    
    # Sign with CA (YubiKey or file-based)
    if is_yubikey_ca; then
        # YubiKey signing
        if ! check_yubikey_connected; then
            die "YubiKey not connected. Please insert your YubiKey."
        fi
        sign_with_yubikey "$csr_file" "$crt_file" "$EXT_SECTION" "$CERT_DAYS"
    else
        # Traditional file-based signing
        local ca_pass_opt=""
        if [[ -n "${CA_PASS:-}" ]]; then
            ca_pass_opt="-passin pass:$CA_PASS"
        fi
        
        # Create temporary config with updated validity
        local temp_config
        temp_config=$(mktemp)
        sed "s|default_days      = 365|default_days      = $CERT_DAYS|g" "$CA_CONFIG" > "$temp_config"
        
        if ! openssl ca -batch \
            -config "$temp_config" \
            -keyfile "$CA_KEY" \
            $ca_pass_opt \
            -cert "$CA_CRT" \
            -in "$csr_file" \
            -out "$crt_file" \
            -extensions "$EXT_SECTION" \
            -notext; then
            rm -f "$temp_config"
            die "Failed to sign certificate. Check CA configuration and permissions."
        fi
        
        rm -f "$temp_config"
    fi
    
    # Verify the certificate was created
    if [[ ! -f "$crt_file" ]] || [[ ! -s "$crt_file" ]]; then
        die "Certificate file was not created or is empty"
    fi
    
    # Create full chain PEM (cert + CA cert)
    cat "$crt_file" "$CA_CRT" > "$pem_file"
    
    # Export to PFX
    local pfx_pass_opt
    if [[ -n "${PFX_PASS:-}" ]]; then
        pfx_pass_opt="-passout pass:$PFX_PASS"
    else
        pfx_pass_opt="-passout pass:"
    fi
    
    openssl pkcs12 -export \
        -out "$pfx_file" \
        -inkey "$key_file" \
        -in "$crt_file" \
        -certfile "$CA_CRT" \
        -name "$CN" \
        $pfx_pass_opt || log_warn "PFX export failed"
    
    # Create additional export formats
    
    # .pem - Certificate only in PEM format (same content as .crt, different extension)
    # Many services like UniFi, nginx prefer .pem extension
    cp "$crt_file" "$cert_pem_file" || log_warn "Failed to create .pem file"
    
    # -chain.pem - CA chain only (for services that want chain separate)
    cp "$CA_CRT" "$chain_pem_file" || log_warn "Failed to create chain.pem file"
    
    # -bundle.pem - Everything in one file: key + cert + chain
    # Useful for HAProxy, some load balancers
    cat "$key_file" "$crt_file" "$CA_CRT" > "$bundle_pem_file" || log_warn "Failed to create bundle.pem file"
    chmod 600 "$bundle_pem_file"
    
    # DER format exports (binary format, used by some Java apps, Windows)
    openssl x509 -in "$crt_file" -outform DER -out "$cert_der_file" || log_warn "Failed to create DER cert"
    
    # Private key in DER format
    if [[ "$key_type" == "rsa" ]]; then
        openssl rsa -in "$key_file" -outform DER -out "$key_der_file" 2>/dev/null || log_warn "Failed to create DER key"
    else
        openssl ec -in "$key_file" -outform DER -out "$key_der_file" 2>/dev/null || log_warn "Failed to create DER key"
    fi
    chmod 600 "$key_der_file"
    
    # Clean up CSR and any numbered cert files from openssl ca (like 1000.pem, 1001.pem)
    rm -f "$csr_file"
    rm -f "$CA_DIR"/[0-9]*.pem 2>/dev/null || true
    
    log_success "$key_type certificate created:"
    echo ""
    echo "    === Standard Formats ==="
    echo "    Private Key (PEM):    $key_file"
    echo "    Certificate (CRT):    $crt_file"
    echo "    Certificate (PEM):    $cert_pem_file"
    echo "    Full Chain (PEM):     $pem_file"
    echo "    PKCS#12 (PFX):        $pfx_file"
    echo ""
    echo "    === Additional Formats ==="
    echo "    CA Chain only:        $chain_pem_file"
    echo "    Bundle (key+cert+ca): $bundle_pem_file"
    echo "    Certificate (DER):    $cert_der_file"
    echo "    Private Key (DER):    $key_der_file"
    echo ""
    echo "    === Usage Tips ==="
    echo "    UniFi:        Use .key + .pem (or fullchain.pem)"
    echo "    nginx:        Use .key + -fullchain.pem"
    echo "    Apache:       Use .key + .crt + -chain.pem"
    echo "    HAProxy:      Use -bundle.pem"
    echo "    Windows/IIS:  Use .pfx"
    echo "    Java:         Use .der files or import .pfx to keystore"
    echo ""
}

issue_certificate() {
    log_info "=== Issue New Certificate ==="
    
    # Get CA passphrase if needed
    get_ca_passphrase
    
    # Select certificate type
    select_cert_type
    
    # Select key options
    select_key_options
    
    # Get certificate details
    get_cert_details
    
    # Get SAN entries
    get_san_entries
    
    # Get PFX passphrase
    echo ""
    read_passphrase "Enter passphrase for PFX export (press Enter for none): " PFX_PASS false
    
    echo ""
    log_info "Generating certificates..."
    echo ""
    
    # Generate certificates
    if [[ "$GENERATE_RSA" == "true" ]]; then
        generate_certificate "rsa" "$RSA_SIZE"
    fi
    
    if [[ "$GENERATE_EC" == "true" ]]; then
        generate_certificate "ec" "$EC_CURVE"
    fi
    
    log_success "Certificate generation complete!"
}

# -----------------------------------------------------------------------------
# Certificate Management Functions
# -----------------------------------------------------------------------------
list_certificates() {
    log_info "=== Issued Certificates ==="
    echo ""
    
    if [[ ! -f "$INDEX" ]] || [[ ! -s "$INDEX" ]]; then
        echo "No certificates have been issued yet."
        return
    fi
    
    echo "Status | Serial | Expiry | Subject"
    echo "-------|--------|--------|--------"
    
    while IFS=$'\t' read -r status expiry revoke serial unknown subject; do
        local status_text
        case "$status" in
            V) status_text="Valid " ;;
            R) status_text="Revoked" ;;
            E) status_text="Expired" ;;
            *) status_text="Unknown" ;;
        esac
        
        # Format expiry date
        local expiry_formatted="${expiry:0:2}/${expiry:2:2}/20${expiry:4:2}"
        
        echo "$status_text | $serial | $expiry_formatted | $subject"
    done < "$INDEX"
}

inspect_certificate() {
    echo ""
    read -rp "Enter path to certificate file: " cert_path
    
    if [[ ! -f "$cert_path" ]]; then
        die "Certificate file not found: $cert_path"
    fi
    
    echo ""
    log_info "=== Certificate Details ==="
    echo ""
    
    openssl x509 -in "$cert_path" -noout -text | head -50
    
    echo ""
    echo "--- Validity ---"
    openssl x509 -in "$cert_path" -noout -dates
    
    echo ""
    echo "--- Subject Alternative Names ---"
    openssl x509 -in "$cert_path" -noout -ext subjectAltName 2>/dev/null || echo "No SANs found"
    
    echo ""
    echo "--- Key Usage ---"
    openssl x509 -in "$cert_path" -noout -ext keyUsage 2>/dev/null || echo "Not specified"
    
    echo ""
    echo "--- Extended Key Usage ---"
    openssl x509 -in "$cert_path" -noout -ext extendedKeyUsage 2>/dev/null || echo "Not specified"
    
    echo ""
    echo "--- Fingerprints ---"
    echo "SHA-256: $(openssl x509 -in "$cert_path" -noout -fingerprint -sha256 | cut -d= -f2)"
    echo "SHA-1:   $(openssl x509 -in "$cert_path" -noout -fingerprint -sha1 | cut -d= -f2)"
}

verify_certificate() {
    echo ""
    read -rp "Enter path to certificate file: " cert_path
    
    if [[ ! -f "$cert_path" ]]; then
        die "Certificate file not found: $cert_path"
    fi
    
    echo ""
    log_info "Verifying certificate against CA..."
    
    if openssl verify -CAfile "$CA_CRT" "$cert_path"; then
        log_success "Certificate is valid and chains to the CA"
    else
        log_error "Certificate verification failed"
    fi
    
    # Check expiry
    echo ""
    if openssl x509 -in "$cert_path" -noout -checkend 0; then
        local days_left
        days_left=$(openssl x509 -in "$cert_path" -noout -enddate | cut -d= -f2)
        log_info "Certificate is not expired (expires: $days_left)"
    else
        log_warn "Certificate has EXPIRED"
    fi
}

generate_crl() {
    log_info "Generating Certificate Revocation List..."
    
    get_ca_passphrase
    
    local ca_pass_opt=""
    if [[ -n "${CA_PASS:-}" ]]; then
        ca_pass_opt="-passin pass:$CA_PASS"
    fi
    
    openssl ca -gencrl \
        -config "$CA_CONFIG" \
        -keyfile "$CA_KEY" \
        $ca_pass_opt \
        -cert "$CA_CRT" \
        -out "$CRL_FILE" \
        2>/dev/null
    
    log_success "CRL generated: $CRL_FILE"
    
    # Show CRL info
    openssl crl -in "$CRL_FILE" -noout -text | head -20
}

revoke_certificate() {
    echo ""
    read -rp "Enter path to certificate to revoke: " cert_path
    
    if [[ ! -f "$cert_path" ]]; then
        die "Certificate file not found: $cert_path"
    fi
    
    # Show cert info first
    echo ""
    echo "Certificate to revoke:"
    openssl x509 -in "$cert_path" -noout -subject -serial
    echo ""
    
    read -rp "Are you sure you want to revoke this certificate? (yes/no): " confirm
    if [[ "$confirm" != "yes" ]]; then
        echo "Revocation cancelled."
        return
    fi
    
    get_ca_passphrase
    
    local ca_pass_opt=""
    if [[ -n "${CA_PASS:-}" ]]; then
        ca_pass_opt="-passin pass:$CA_PASS"
    fi
    
    openssl ca \
        -config "$CA_CONFIG" \
        -keyfile "$CA_KEY" \
        $ca_pass_opt \
        -cert "$CA_CRT" \
        -revoke "$cert_path" \
        2>/dev/null
    
    log_success "Certificate revoked"
    log_info "Don't forget to regenerate the CRL"
}

backup_ca() {
    local backup_file="ca-backup-$(date +%Y%m%d-%H%M%S).tar.gz"
    
    log_info "Creating CA backup..."
    tar -czf "$backup_file" "$CA_DIR"
    
    log_success "CA backed up to: $backup_file"
    log_warn "Store this backup securely - it contains your CA private key!"
}

# -----------------------------------------------------------------------------
# Main Menu
# -----------------------------------------------------------------------------
show_menu() {
    echo ""
    echo "========================================"
    echo "     PKI Certificate Management Tool"
    echo "              Version $SCRIPT_VERSION"
    echo "========================================"
    echo ""
    
    if check_ca; then
        local ca_subject
        ca_subject=$(openssl x509 -in "$CA_CRT" -noout -subject | sed 's/subject=//')
        echo "CA: $ca_subject"
        local ca_expiry
        ca_expiry=$(openssl x509 -in "$CA_CRT" -noout -enddate | cut -d= -f2)
        echo "Expires: $ca_expiry"
        if is_yubikey_ca; then
            echo -e "Key Storage: ${GREEN}YubiKey (slot $YUBIKEY_SLOT)${NC}"
        else
            echo "Key Storage: File-based"
        fi
    else
        echo "CA: Not configured"
    fi
    
    echo ""
    echo "  Certificate Authority:"
    echo "    1) Create new CA"
    echo "    2) Backup CA"
    echo ""
    echo "  Certificates:"
    echo "    3) Issue new certificate"
    echo "    4) List issued certificates"
    echo "    5) Inspect certificate"
    echo "    6) Verify certificate"
    echo ""
    echo "  Revocation:"
    echo "    7) Revoke certificate"
    echo "    8) Generate CRL"
    echo ""
    echo "  YubiKey:"
    echo "    9) YubiKey status"
    echo ""
    echo "    0) Exit"
    echo ""
    read -rp "Select option: " choice
    
    case "$choice" in
        1)
            if check_ca; then
                log_warn "CA already exists!"
                read -rp "Do you want to create a NEW CA (this will overwrite the existing one)? (yes/no): " confirm
                if [[ "$confirm" != "yes" ]]; then
                    return
                fi
                backup_ca
            fi
            create_ca
            ;;
        2)
            if ! check_ca; then
                die "No CA exists to backup"
            fi
            backup_ca
            ;;
        3)
            if ! check_ca; then
                log_warn "No CA exists. Creating one first..."
                create_ca
            fi
            issue_certificate
            ;;
        4)
            if ! check_ca; then
                die "No CA exists"
            fi
            list_certificates
            ;;
        5)
            inspect_certificate
            ;;
        6)
            if ! check_ca; then
                die "No CA exists for verification"
            fi
            verify_certificate
            ;;
        7)
            if ! check_ca; then
                die "No CA exists"
            fi
            revoke_certificate
            ;;
        8)
            if ! check_ca; then
                die "No CA exists"
            fi
            generate_crl
            ;;
        9)
            show_yubikey_status
            ;;
        0)
            echo ""
            echo "Goodbye! (PKI Tool v$SCRIPT_VERSION)"
            exit 0
            ;;
        *)
            log_error "Invalid option"
            ;;
    esac
}

# -----------------------------------------------------------------------------
# Main Entry Point
# -----------------------------------------------------------------------------
main() {
    check_dependencies
    
    # If arguments provided, could add CLI mode here
    # For now, always show menu
    
    while true; do
        show_menu
    done
}

main "$@"

