    fi
}

# -----------------------------------------------------------------------------
# CA Management Functions
# -----------------------------------------------------------------------------
create_ca_config() {
    # Create new_certs directory for openssl ca
    mkdir -p "$CA_DIR/newcerts"
    
    cat > "$CA_CONFIG" <<-EOFCONFIG
# OpenSSL CA Configuration
[ ca ]
default_ca = local_ca

[ local_ca ]
dir               = $CA_DIR
certificate       = \$dir/ca.crt
database          = \$dir/index.txt
private_key       = \$dir/ca.key
serial            = \$dir/serial
crlnumber         = \$dir/crlnumber
crl               = \$dir/ca.crl
new_certs_dir     = \$dir/newcerts
default_days      = 365
default_crl_days  = 30
default_md        = sha256
copy_extensions   = copy
unique_subject    = no
policy            = policy_loose
x509_extensions   = usr_cert
preserve          = no
email_in_dn       = no

[ policy_loose ]
countryName             = optional
stateOrProvinceName     = optional
localityName            = optional
organizationName        = optional
organizationalUnitName  = optional
commonName              = supplied
emailAddress            = optional

[ req ]
prompt              = no
distinguished_name  = req_distinguished_name
string_mask         = utf8only
default_md          = sha256

[ req_distinguished_name ]
# Empty - we use -subj on command line

# -----------------------------------------------------------------------------
# Certificate Extensions
# -----------------------------------------------------------------------------

# Generic user certificate
[ usr_cert ]
basicConstraints       = CA:FALSE
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer

# Web Server (TLS Server Authentication)
[ web_server ]
basicConstraints       = CA:FALSE
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = serverAuth
# Note: SAN is added via copy_extensions from CSR

# RADIUS Server (EAP-TLS server)
[ radius_server ]
basicConstraints       = CA:FALSE
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = serverAuth, 1.3.6.1.5.5.7.3.14
# 1.3.6.1.5.5.7.3.14 = id-kp-eapOverLAN (EAP over LAN)

# VPN Server (IPsec/IKEv2)
[ vpn_server ]
basicConstraints       = CA:FALSE
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = serverAuth, 1.3.6.1.5.5.7.3.5
# 1.3.6.1.5.5.7.3.5 = id-kp-ipsecEndSystem

# Generic TLS Client
[ tls_client ]
basicConstraints       = CA:FALSE
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
keyUsage               = critical, digitalSignature
extendedKeyUsage       = clientAuth

# WiFi Client (EAP-TLS / WPA Enterprise)
[ wifi_client ]
basicConstraints       = CA:FALSE
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
keyUsage               = critical, digitalSignature
extendedKeyUsage       = clientAuth, 1.3.6.1.5.5.7.3.14
# 1.3.6.1.5.5.7.3.14 = id-kp-eapOverLAN

# VPN Client
[ vpn_client ]
basicConstraints       = CA:FALSE
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
keyUsage               = critical, digitalSignature
extendedKeyUsage       = clientAuth, 1.3.6.1.5.5.7.3.5

# Code Signing
[ code_signing ]
basicConstraints       = CA:FALSE
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
keyUsage               = critical, digitalSignature
extendedKeyUsage       = codeSigning, msCodeInd, msCodeCom

# Email (S/MIME)
[ email_cert ]
basicConstraints       = CA:FALSE
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = emailProtection

# Intermediate CA
[ intermediate_ca ]
basicConstraints       = critical, CA:TRUE, pathlen:0
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
keyUsage               = critical, keyCertSign, cRLSign

# OCSP Signing
[ ocsp_signing ]
basicConstraints       = CA:FALSE
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
keyUsage               = critical, digitalSignature
extendedKeyUsage       = OCSPSigning
EOFCONFIG
    log_success "CA configuration file created"
}

create_ca() {
    log_info "Creating new Certificate Authority..."
    
    mkdir -p "$CA_DIR"
    
    # Ask about key storage method
    echo ""
    echo "Select CA private key storage method:"
    echo "  1) File-based (traditional - key stored in $CA_DIR/ca.key)"
    echo "  2) YubiKey hardware token (key stored on YubiKey PIV slot 9c)"
    read -rp "Choice [1]: " storage_method
    storage_method="${storage_method:-1}"
    
    if [[ "$storage_method" == "2" ]]; then
        create_ca_with_yubikey
        return
    fi
    
    # Traditional file-based CA creation
    create_ca_file_based
}

create_ca_file_based() {
    # Get CA details
    local ca_cn ca_days ca_key_type ca_key_size ca_curve ca_pass
    
    read -rp "Enter CA Common Name (e.g., My Root CA): " ca_cn
    validate_cn "$ca_cn"
    
    read -rp "Enter CA validity in days [$DEFAULT_CA_DAYS]: " ca_days
    ca_days="${ca_days:-$DEFAULT_CA_DAYS}"
    validate_number "$ca_days" 1 36500 "CA validity"
    
    echo ""
    echo "Select CA key type:"
    echo "  1) RSA (recommended for compatibility)"
    echo "  2) ECDSA (smaller, faster)"
    read -rp "Choice [1]: " ca_key_type
    ca_key_type="${ca_key_type:-1}"
    
    if [[ "$ca_key_type" == "1" ]]; then
        echo "Select RSA key size:"
        echo "  1) 2048 bits (minimum)"
        echo "  2) 3072 bits (good)"
        echo "  3) 4096 bits (recommended)"
        read -rp "Choice [3]: " ca_key_size
        ca_key_size="${ca_key_size:-3}"
        case "$ca_key_size" in
            1) ca_key_size=2048 ;;
            2) ca_key_size=3072 ;;
            3) ca_key_size=4096 ;;
            *) die "Invalid key size selection" ;;
        esac
        
        read_passphrase "Enter CA private key passphrase (recommended, press Enter for none): " ca_pass false
        
        if [[ -n "$ca_pass" ]]; then
            openssl genrsa -aes256 -passout pass:"$ca_pass" -out "$CA_KEY" "$ca_key_size"
            openssl req -new -x509 -days "$ca_days" -key "$CA_KEY" -passin pass:"$ca_pass" \
                -out "$CA_CRT" -subj "/CN=$ca_cn" \
                -addext "basicConstraints=critical,CA:TRUE" \
                -addext "keyUsage=critical,keyCertSign,cRLSign" \
                -addext "subjectKeyIdentifier=hash"
        else
            openssl genrsa -out "$CA_KEY" "$ca_key_size"
            openssl req -new -x509 -days "$ca_days" -key "$CA_KEY" \
                -out "$CA_CRT" -subj "/CN=$ca_cn" \
                -addext "basicConstraints=critical,CA:TRUE" \
                -addext "keyUsage=critical,keyCertSign,cRLSign" \
                -addext "subjectKeyIdentifier=hash"
        fi
    else
        echo "Select EC curve:"
        echo "  1) prime256v1 / P-256 (most compatible)"
        echo "  2) secp384r1 / P-384 (stronger)"
        echo "  3) secp521r1 / P-521 (strongest)"
        read -rp "Choice [1]: " ca_curve
        ca_curve="${ca_curve:-1}"
        case "$ca_curve" in
            1) ca_curve="prime256v1" ;;
            2) ca_curve="secp384r1" ;;
            3) ca_curve="secp521r1" ;;
            *) die "Invalid curve selection" ;;
        esac
        
        read_passphrase "Enter CA private key passphrase (recommended, press Enter for none): " ca_pass false
        
        if [[ -n "$ca_pass" ]]; then
            openssl ecparam -name "$ca_curve" -genkey | \
                openssl ec -aes256 -passout pass:"$ca_pass" -out "$CA_KEY"
            openssl req -new -x509 -days "$ca_days" -key "$CA_KEY" -passin pass:"$ca_pass" \
                -out "$CA_CRT" -subj "/CN=$ca_cn" \
                -addext "basicConstraints=critical,CA:TRUE" \
                -addext "keyUsage=critical,keyCertSign,cRLSign" \
                -addext "subjectKeyIdentifier=hash"
        else
            openssl ecparam -name "$ca_curve" -genkey -noout -out "$CA_KEY"
            openssl req -new -x509 -days "$ca_days" -key "$CA_KEY" \
                -out "$CA_CRT" -subj "/CN=$ca_cn" \
                -addext "basicConstraints=critical,CA:TRUE" \
                -addext "keyUsage=critical,keyCertSign,cRLSign" \
                -addext "subjectKeyIdentifier=hash"
        fi
    fi
    
    # Initialize CA database files
    touch "$INDEX"
    echo "unique_subject = no" > "$INDEX_ATTR"
    generate_serial > "$SERIAL"
    echo "1000" > "$CRL_NUMBER"
    
    # Create CA config
    create_ca_config
    
    # Set restrictive permissions on CA private key
    chmod 600 "$CA_KEY"
    
    # Create ca.pem copy for services like FreeRADIUS
    cp "$CA_CRT" "$CA_DIR/ca.pem"
    
    log_success "Certificate Authority created successfully!"
    log_info "CA Certificate: $CA_CRT (also available as $CA_DIR/ca.pem)"
    log_info "CA Private Key: $CA_KEY (keep this safe!)"
    echo ""
    
    # Show CA info
    openssl x509 -in "$CA_CRT" -noout -subject -dates
}

create_ca_with_yubikey() {
    log_info "Creating Certificate Authority with YubiKey..."
    echo ""
    
    # Check YubiKey tools are available
    if ! check_yubikey_tools; then
        die "YubiKey tools not available. See REQUIREMENTS.md"
    fi
    
    # Check YubiKey is connected
    if ! check_yubikey_connected; then
        die "Please insert your YubiKey and try again"
    fi
    
    # Get CA details
    local ca_cn ca_days
    
    read -rp "Enter CA Common Name (e.g., My Root CA): " ca_cn
    validate_cn "$ca_cn"
    
    read -rp "Enter CA validity in days [$DEFAULT_CA_DAYS]: " ca_days
    ca_days="${ca_days:-$DEFAULT_CA_DAYS}"
    validate_number "$ca_days" 1 36500 "CA validity"
    
    # Key generation method
    echo ""
    echo "Select key generation method:"
    echo "  1) Generate new key ON YubiKey (non-exportable, most secure)"
    echo "  2) Import existing key TO YubiKey (allows backup)"
    read -rp "Choice [1]: " key_method
    key_method="${key_method:-1}"
    
    # Algorithm selection (YubiKey supports RSA2048, ECCP256, ECCP384)
    echo ""
    echo "Select key algorithm (YubiKey supported):"
    echo "  1) RSA 2048 (best compatibility)"
    echo "  2) EC P-256 (faster, smaller)"
    echo "  3) EC P-384 (stronger EC)"
    read -rp "Choice [1]: " algo_choice
    algo_choice="${algo_choice:-1}"
    
    local algorithm
    case "$algo_choice" in
        1) algorithm="RSA2048" ;;
        2) algorithm="ECCP256" ;;
        3) algorithm="ECCP384" ;;
        *) die "Invalid algorithm selection" ;;
    esac
    
    # PIN policy
    echo ""
    echo "Select PIN policy for signing operations:"
    echo "  1) once    - PIN required once per session"
    echo "  2) always  - PIN required for every signature (most secure)"
    echo "  3) never   - PIN never required (least secure)"
    read -rp "Choice [2]: " pin_policy_choice
    pin_policy_choice="${pin_policy_choice:-2}"
    
    local pin_policy
    case "$pin_policy_choice" in
        1) pin_policy="once" ;;
        2) pin_policy="always" ;;
        3) pin_policy="never" ;;
        *) die "Invalid PIN policy selection" ;;
    esac
    
    # Touch policy
    echo ""
    echo "Select touch policy (physical touch on YubiKey):"
    echo "  1) never  - No touch required"
    echo "  2) always - Touch required for every signature (recommended)"
    echo "  3) cached - Touch cached for 15 seconds"
    read -rp "Choice [2]: " touch_policy_choice
    touch_policy_choice="${touch_policy_choice:-2}"
    
    local touch_policy
    case "$touch_policy_choice" in
        1) touch_policy="never" ;;
        2) touch_policy="always" ;;
        3) touch_policy="cached" ;;
        *) die "Invalid touch policy selection" ;;
    esac
    
    # Get management key
    local mgmt_key
    mgmt_key=$(get_management_key)
    
    # Get PIN
    local yk_pin
    get_yubikey_pin yk_pin
    
    mkdir -p "$CA_DIR"
    
    if [[ "$key_method" == "1" ]]; then
        # Generate key on YubiKey
        log_warn "Generating key on YubiKey - this key will be NON-EXPORTABLE!"
        echo ""
        read -rp "Are you sure you want to continue? (yes/no): " confirm
        if [[ "$confirm" != "yes" ]]; then
            echo "Cancelled."
            return
        fi
        
        local pubkey_file
        pubkey_file=$(generate_ca_key_on_yubikey "$algorithm" "$pin_policy" "$touch_policy" "$mgmt_key")
        
        # Create self-signed certificate
        create_ca_cert_with_yubikey "$pubkey_file" "$ca_cn" "$ca_days" "$yk_pin"
        
        # Import certificate back to YubiKey
        import_ca_cert_to_yubikey "$CA_CRT" "$mgmt_key"
        
    else
        # Import existing key
        echo ""
        read -rp "Enter path to existing CA private key file: " existing_key
        
        if [[ ! -f "$existing_key" ]]; then
            die "Key file not found: $existing_key"
        fi
        
        # Check if we also have an existing certificate
        read -rp "Do you have an existing CA certificate? (yes/no) [no]: " has_cert
        has_cert="${has_cert:-no}"
        
        if [[ "$has_cert" == "yes" ]]; then
            read -rp "Enter path to existing CA certificate: " existing_cert
            if [[ ! -f "$existing_cert" ]]; then
                die "Certificate file not found: $existing_cert"
            fi
            cp "$existing_cert" "$CA_CRT"
        fi
        
        # Import key to YubiKey
        import_ca_key_to_yubikey "$existing_key" "$mgmt_key" "$pin_policy" "$touch_policy"
        
        if [[ "$has_cert" != "yes" ]]; then
            # Need to create certificate - extract public key first
            local pubkey_file="$CA_DIR/ca_pubkey.pem"
            
            # Check key type and extract public key
            if openssl rsa -in "$existing_key" -pubout -out "$pubkey_file" 2>/dev/null; then
                : # RSA key
            elif openssl ec -in "$existing_key" -pubout -out "$pubkey_file" 2>/dev/null; then
                : # EC key
            else
                die "Could not extract public key from $existing_key"
            fi
            
            # Create self-signed certificate
            create_ca_cert_with_yubikey "$pubkey_file" "$ca_cn" "$ca_days" "$yk_pin"
        fi
        
        # Import certificate to YubiKey
        import_ca_cert_to_yubikey "$CA_CRT" "$mgmt_key"
        
        log_warn ""
        log_warn "IMPORTANT: Consider securely deleting the original key file:"
        log_warn "  shred -u $existing_key"
        log_warn "Or keep it as a backup in a secure location."
    fi
    
    # Create marker file to indicate YubiKey mode
    echo "yubikey" > "$YUBIKEY_MODE_FILE"
    echo "slot=$YUBIKEY_SLOT" >> "$YUBIKEY_MODE_FILE"
    echo "algorithm=$algorithm" >> "$YUBIKEY_MODE_FILE"
    
    # Create a dummy key file to pass check_ca (actual key is on YubiKey)
    echo "# CA private key stored on YubiKey PIV slot $YUBIKEY_SLOT" > "$CA_KEY"
    echo "# DO NOT DELETE - This file indicates YubiKey mode" >> "$CA_KEY"
    chmod 600 "$CA_KEY"
    
    # Initialize CA database files
    touch "$INDEX"
    echo "unique_subject = no" > "$INDEX_ATTR"
    generate_serial > "$SERIAL"
    echo "1000" > "$CRL_NUMBER"
    
    # Create CA config
    create_ca_config
    
    # Create ca.pem copy
    cp "$CA_CRT" "$CA_DIR/ca.pem"
    
    log_success "Certificate Authority created with YubiKey!"
    log_info "CA Certificate: $CA_CRT (also available as $CA_DIR/ca.pem)"
    log_info "CA Private Key: Stored on YubiKey slot $YUBIKEY_SLOT"
    log_warn "PIN Policy: $pin_policy | Touch Policy: $touch_policy"
    echo ""
    
    # Show CA info
    openssl x509 -in "$CA_CRT" -noout -subject -dates
}

# Check if CA exists and is valid
check_ca() {
    # For YubiKey mode, check if mode file exists
    if [[ -f "$YUBIKEY_MODE_FILE" ]]; then
        if [[ ! -f "$CA_CRT" ]]; then
            return 1
        fi
        # Verify CA cert is valid
        if ! openssl x509 -in "$CA_CRT" -noout -checkend 0 2>/dev/null; then
            log_warn "CA certificate has expired!"
            return 1
        fi
        return 0
    fi
    
    # Traditional file-based check
    if [[ ! -f "$CA_KEY" ]] || [[ ! -f "$CA_CRT" ]]; then
        return 1
    fi
    
    # Verify CA cert is valid
    if ! openssl x509 -in "$CA_CRT" -noout -checkend 0 2>/dev/null; then
        log_warn "CA certificate has expired!"
        return 1
    fi
    
    return 0
}

# Get CA passphrase if needed
get_ca_passphrase() {
    CA_PASS=""
    
    # YubiKey mode doesn't use file-based passphrase
    if is_yubikey_ca; then
        return 0
    fi
    
    # Check if CA key is encrypted
    if grep -q "ENCRYPTED" "$CA_KEY" 2>/dev/null; then
        read_passphrase "Enter CA private key passphrase: " CA_PASS false
        
        # Verify passphrase works
        if ! openssl rsa -in "$CA_KEY" -passin pass:"$CA_PASS" -check -noout 2>/dev/null; then
            if ! openssl ec -in "$CA_KEY" -passin pass:"$CA_PASS" -check -noout 2>/dev/null; then
                die "Invalid CA passphrase"
            fi
        fi
    fi
}

